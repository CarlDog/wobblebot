# Environment Variables Template
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control

# ============================================================================
# Kraken API Credentials
# ============================================================================
# Trading API Key (should NOT have withdrawal permissions)
KRAKEN_API_KEY=your_api_key_here
KRAKEN_API_SECRET=your_api_secret_here

# Harvester API Key (has withdrawal permissions - separate from trading key)
# Only needed in Phase 4+
KRAKEN_HARVESTER_API_KEY=your_harvester_api_key_here
KRAKEN_HARVESTER_API_SECRET=your_harvester_api_secret_here

# ============================================================================
# Application Configuration
# ============================================================================
# Operating mode: sandbox, dev, live-low-risk, production
WOBBLEBOT_MODE=sandbox

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# Database
# ============================================================================
# SQLite database path (relative to project root)
DATABASE_PATH=data/wobblebot.db

# ============================================================================
# LLM / Strategy Advisor (Phase 3+)
# ============================================================================
# LLM provider: ollama, openai, anthropic
LLM_PROVIDER=ollama

# Ollama settings (for local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# OpenAI settings (if using OpenAI)
# OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# Banking / Harvester (Phase 4+)
# ============================================================================
# Banking integration details (TBD based on bank APIs)
# BANK_API_KEY=your_bank_api_key_here

# ============================================================================
# Notifications (Future)
# ============================================================================
# Email, Slack, Discord, etc.
# NOTIFICATION_EMAIL=your@email.com
