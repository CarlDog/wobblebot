# WobbleBot Environment Variables (Example)
#
# Copy this file to `.env` and fill in your real values. The committed
# example file documents every env var WobbleBot reads; .env stays
# gitignored and holds your actual secrets.
#
# Per the project's standing rule, .env.example and .env stay
# schema-aligned: same keys, same comments, same section ordering —
# only VALUES differ. The schema-drift test suite catches drift.
# Set WOBBLEBOT_STRICT_CONFIG_DRIFT=1 to make the test fail in both
# directions (i.e. also fail when .env is missing keys that .env.example
# documents); the default is one-way (operator stale keys fail; missing
# new keys warn).

# ============================================================================
# Kraken read-only key (Phase 2.1+, required for cli/status, cli/observe,
# cli/shadow)
# ============================================================================
# Permissions: Query Funds + Query open & closed orders & trades.
# NOT used for placing orders — the trade key below is separate so the
# read path can keep working even if the trade key is rotated.
KRAKEN_API_KEY=your_read_only_key_here
KRAKEN_API_SECRET=your_read_only_secret_here

# Optional: override the Kraken REST base URL (used by tests + sandbox
# transports). Production should leave this unset to use the public API.
# KRAKEN_BASE_URL=https://api.kraken.com

# ============================================================================
# Kraken trade key (Phase 2.3+, required for cli/preflight and cli/live)
# ============================================================================
# Permissions: Query Funds + Query open & closed orders & trades +
# Create & modify orders + Cancel & close orders. The Withdraw scope
# MUST stay off — that scope is exclusive to the future Phase 4
# Harvester key. IP-address restriction recommended.
KRAKEN_TRADE_API_KEY=your_trade_key_here
KRAKEN_TRADE_API_SECRET=your_trade_secret_here

# ============================================================================
# Kraken harvester key (Phase 4 — not yet active)
# ============================================================================
# Per ADR-003, the Harvester is the SOLE module with withdrawal
# authority. Its key is separate from the trade key so trading code can
# never accidentally initiate a transfer. Leave commented-out until
# Phase 4 ships.
# KRAKEN_HARVESTER_API_KEY=your_harvester_key_here
# KRAKEN_HARVESTER_API_SECRET=your_harvester_secret_here

# ============================================================================
# Logging overrides (optional)
# ============================================================================
# Either of these may also be passed via --log-format on each CLI; the
# CLI flag wins when present.
# WOBBLEBOT_LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR
# WOBBLEBOT_LOG_FORMAT=plain      # plain | json

# ============================================================================
# Cloud LLM API keys (Phase 3+ for MoE advisor, Phase 6 for operator-
# assistant + full cloud advisor adapters — optional)
# ============================================================================
# Per ADR-007, cloud and local LLMs can mix freely as MoE experts. Per
# Phase 6 (ADR-014 cost caps + ADR-015 failover policy), the same keys
# also drive the operator-assistant (cli/operator) and the full cloud
# advisor lineup (cli/advise). Each provider only needs its key set
# when actually referenced by a configured provider= in settings.yml.
# Set the `llm:` block in settings.yml to gate cloud spend with ADR-014
# daily + session USD caps; uncommenting these keys alone does NOT
# enable cloud usage — the model/provider in advisor.* or operator.*
# is the actual switch.
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
# Optional: pin requests to a specific OpenAI organization. Most
# operators leave this unset (default org is used). Set when you
# have multiple orgs and need to direct billing to a specific one.
# OPENAI_ORGANIZATION=your_openai_org_id_here
# GOOGLE_API_KEY=your_google_ai_studio_key_here

# ============================================================================
# Local LLM endpoint (Phase 3+, optional)
# ============================================================================
# Default works for a local Ollama install. Override only if you run
# Ollama on a different host/port or are using another local server.
# OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# News ingestion API keys (Stage 3.2.5, optional)
# ============================================================================
# Each adapter only needs its key set when the operator has enabled
# the corresponding source in news.*.enabled. RSS adapters have no
# auth — only CryptoCompare requires a key.
#
# CryptoCompare News (free tier). Create at:
#   https://www.cryptocompare.com/cryptopian/api-keys
# Minimum scope: "Poll Live and Historical Data". Anything more is
# unnecessary; don't enable "Full Read/Write All Data".
# CRYPTOCOMPARE_API_KEY=your_cryptocompare_key_here

# ============================================================================
# Web UI session secret (Phase 7 — Stage 7.1+, required for cli/web)
# ============================================================================
# Per ADR-017, the FastAPI dashboard signs its session cookie with
# this key. Must be 32+ random bytes; the cookie is invalidated when
# the key changes (operators are logged out + the rate-limit bucket
# resets — both are fine for a one-time rotation).
# Mint with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave commented-out unless cli/web is in use; cli/web serve refuses
# to start without it.
# WOBBLEBOT_WEB_SESSION_SECRET=your_32_byte_urlsafe_token_here

# ============================================================================
# Discord bot token (Phase 5 — Stage 5.6+, required for cli/operator)
# ============================================================================
# Per ADR-013, cli/operator wraps a discord.py Gateway client to provide
# the bidirectional operator surface. Mint a bot at
#   https://discord.com/developers/applications → New Application → Bot.
# Enable the "Message Content Intent" (privileged) before connecting —
# the daemon reads operator message text.
# Leave commented-out unless cli/operator is in use.
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ============================================================================
# Schema drift detection (test infrastructure)
# ============================================================================
# Set to "1" to make tests/config/test_schema_drift.py fail when .env
# or settings.yml are MISSING keys that the example file documents.
# Off by default; enable in CI for stricter enforcement.
# WOBBLEBOT_STRICT_CONFIG_DRIFT=0

# Optional: Discord webhook URL used by tools/probe_discord_bot.py to
# post test messages into the wobblebot channel for prompt-routing
# regression checks. Get one by creating a webhook in the channel
# (Channel Settings → Integrations → Webhooks → New Webhook → copy
# URL). The webhook ID (the long number between /webhooks/ and the
# next /) must ALSO be added to operator.auth.allowed_user_ids in
# settings.yml so the bot accepts inbound messages from the webhook.
# Treat as a credential — anyone with the URL can post to the channel.
# WOBBLEBOT_DISCORD_TEST_WEBHOOK_URL=https://discord.com/api/webhooks/<webhook_id>/<webhook_token>
