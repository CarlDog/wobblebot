# Force LF line endings for files that MUST stay LF on Linux
# regardless of the developer's Git core.autocrlf setting.
#
# Shell scripts in particular: a CRLF shebang line becomes
# `#!/bin/sh\r` which Linux tries to execute as a literal binary
# called `sh\r`, fails, and the container immediately exits with
# "no such file or directory" — confusing to debug.

# Shell scripts
*.sh           text eol=lf
.githooks/*    text eol=lf

# Container assets — Dockerfile and adjacent configs
docker/Dockerfile  text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf

# Python source
*.py           text eol=lf

# Documentation and config that benefit from cross-platform consistency
*.md           text eol=lf
*.toml         text eol=lf
*.cfg          text eol=lf
*.ini          text eol=lf

# Binary files — never touch these
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.svg          text eol=lf
*.pdf          binary
*.db           binary
*.sqlite       binary
*.sqlite3      binary
