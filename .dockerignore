# Version control
.git/
.gitignore
.gitattributes
.githooks/

# Python build / cache artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / editor cruft
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local secrets and operator-specific config
# (settings.yml + .env are mounted as volumes at runtime,
#  NOT baked into the image)
.env
.env.local
.env.*.local
config/settings.yml
data/
logs/

# Tests and dev-only artifacts
tests/
docs/
scripts/

# Phase-end / planning artifacts that are not runtime-required
tmp_*.py
sweep_*.py
sweep-*.json

# CI / GitHub artifacts
.github/

# NOTE: docker/ is NOT excluded — the Dockerfile needs to COPY
# docker/entrypoint.sh into the image. Excluding the directory
# also drops the entrypoint from the build context. The Dockerfile
# itself is loaded via `-f` and doesn't pollute the context anyway.

# Editor / OS noise
*.log
*.tmp
