# Version control
.git/
.gitignore
.gitattributes
.githooks/

# Python build / cache artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / editor cruft
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local secrets and operator-specific config
# (settings.yml + .env are mounted as volumes at runtime,
#  NOT baked into the image)
.env
.env.local
.env.*.local
config/settings.yml
data/
logs/

# Tests and dev-only artifacts
tests/
docs/
scripts/

# Phase-end / planning artifacts that are not runtime-required
tmp_*.py
sweep_*.py
sweep-*.json

# CI / GitHub artifacts
.github/

# Docker context itself (avoid recursion if compose is run from project root)
docker/

# Editor / OS noise
*.log
*.tmp
