#!/usr/bin/env bash
set -euo pipefail

# Personal-domain email pattern used in two places:
#  - the author-identity check below (step 1)
#  - the PII pattern scan over staged content (step 3)
PERSONAL_EMAIL_PATTERN='[A-Za-z0-9._%+-]+@(gmail|outlook|hotmail|yahoo|icloud|me|live|aol)\.[a-z]{2,}'

# 1. Author identity check
# git's staged-content scan can't see commit metadata, so the author
# email can leak into commit history even when file contents are clean.
# Block personal-domain emails in the configured author identity.
echo "Checking author identity..."
AUTHOR_IDENT=$(git var GIT_AUTHOR_IDENT 2>/dev/null || true)
# git var returns "Name <email> timestamp tz" — extract the email.
AUTHOR_EMAIL=$(printf '%s' "$AUTHOR_IDENT" | sed -nE 's/.*<([^>]+)>.*/\1/p')
if printf '%s' "$AUTHOR_EMAIL" | grep -qE "$PERSONAL_EMAIL_PATTERN"; then
  echo "" >&2
  echo "Commit blocked: author identity uses a personal-domain email." >&2
  echo "  email: $AUTHOR_EMAIL" >&2
  echo "" >&2
  echo "Set a GitHub noreply alias for this repo:" >&2
  echo "  git config user.email '<numeric-id>+<github-login>@users.noreply.github.com'" >&2
  echo "" >&2
  echo "Find your numeric id at https://api.github.com/users/<login>" >&2
  exit 1
fi

# 2. Secret scan via gitleaks
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "ERROR: gitleaks not installed. Install from https://github.com/gitleaks/gitleaks" >&2
  exit 1
fi

echo "Running gitleaks..."
gitleaks protect --staged --redact --config .gitleaks.toml

# 3. PII pattern scan over staged content
# Catches user-home directory references and personal-domain email
# addresses that often leak into committed content (workstation paths,
# author identity, etc.). Patterns are deliberately generic so the hook
# can be committed publicly without itself containing any specific PII.
echo "Running PII pattern check..."

PII_PATTERNS=(
  '[/\\]Users[/\\][A-Za-z0-9._-]+[/\\]'
  '[/\\]home[/\\][A-Za-z0-9._-]+[/\\]'
  "$PERSONAL_EMAIL_PATTERN"
)

STAGED=$(git diff --cached --name-only --diff-filter=AM)
if [ -z "$STAGED" ]; then
  exit 0
fi

FOUND=0
while IFS= read -r file; do
  [ -z "$file" ] && continue
  for pattern in "${PII_PATTERNS[@]}"; do
    matches=$(git show ":$file" 2>/dev/null | grep -nE "$pattern" || true)
    if [ -n "$matches" ]; then
      if [ "$FOUND" -eq 0 ]; then
        echo "" >&2
        echo "PII patterns detected in staged content:" >&2
        FOUND=1
      fi
      echo "  $file" >&2
      printf '%s\n' "$matches" | head -3 | sed 's/^/    /' >&2
    fi
  done
done <<< "$STAGED"

if [ "$FOUND" -ne 0 ]; then
  echo "" >&2
  echo "Scrub the matches and re-stage. To adjust patterns, edit .githooks/pre-commit." >&2
  exit 1
fi

echo "No PII patterns detected."

# 4. Schema-drift check (scoped) — only when an example config file is staged.
# Adding a key/profile to settings.example.yml or .env.example without syncing
# your own (gitignored) settings.yml/.env is the exact drift this catches.
# Strict mode so it BLOCKS; fail-soft if the venv is absent (a missing .venv
# must never block a commit). Scoped to example-file commits so unrelated
# commits pay zero cost.
if printf '%s\n' "$STAGED" | grep -qE '^(config/settings\.example\.yml|\.env\.example)$'; then
  echo "Staged an example config file; checking schema drift..."
  DRIFT_PYTHON=""
  if [ -x ".venv/Scripts/python.exe" ]; then
    DRIFT_PYTHON=".venv/Scripts/python.exe"
  elif [ -x ".venv/bin/python" ]; then
    DRIFT_PYTHON=".venv/bin/python"
  fi
  if [ -z "$DRIFT_PYTHON" ]; then
    echo "  (no .venv found; skipping — run 'pytest tests/config/test_schema_drift.py' manually)" >&2
  elif DRIFT_OUT=$(WOBBLEBOT_STRICT_CONFIG_DRIFT=1 "$DRIFT_PYTHON" -m pytest tests/config/test_schema_drift.py --no-cov -q 2>&1); then
    echo "Schema drift check passed."
  else
    echo "" >&2
    echo "Commit blocked: schema drift between an example config and your operator file." >&2
    echo "You staged an example config change but your gitignored settings.yml/.env is out of sync." >&2
    printf '%s\n' "$DRIFT_OUT" | tail -20 >&2
    echo "" >&2
    echo "Sync the missing key(s)/profile(s) into your settings.yml/.env and re-stage." >&2
    exit 1
  fi
fi
